{
  "schemaVersion": 1,
  "id": "fm-utils",
  "version": "${version}",
  "name": "FM Utils",
  "description": "Auto Cinematic and AFK Utilities",
  "authors": [
    "FordMC"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.fordmc.fmutils.FMUtils"
    ],
    "client": [
